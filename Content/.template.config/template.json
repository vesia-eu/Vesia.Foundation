{
  "$schema": "http://json.schemastore.org/template",
  "author": "Vesia",
  "classifications": [
    "Clean Architecture",
    "CQRS",
    "DDD",
    "Solution Template"
  ],
  "identity": "Vesia.Foundation",
  "name": "Vesia Foundation",
  "shortName": "vesia-foundation",
  "description": "A .NET solution template built on Clean Architecture, CQRS, and DDD — powered by Vesia.Dispatch.",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "sourceName": "Vesia.Template",
  "preferNameDirectory": true,
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target framework for the project.",
      "datatype": "choice",
      "choices": [
        {
          "choice": "net10.0",
          "description": ".NET 10 (LTS)"
        }
      ],
      "defaultValue": "net10.0",
      "replaces": "net10.0"
    }
  }
}
    <packageTypes>
      <packageType name="Template" />
    </packageTypes>
  </metadata>
  <files>
  	<file src="README.md" target="docs\" />
    <file src="**" target="content" exclude="**\bin\**;**\obj\**;**\.git\**;**\.idea\**" />
  </files>
</package>
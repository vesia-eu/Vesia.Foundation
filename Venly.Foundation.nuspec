<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>Venly.Foundation</id>
    <version>1.0.1</version>
    <title>Venly Foundation</title>
    <authors>venly-eu</authors>
    <description>A .NET solution template built on Clean Architecture, CQRS, and DDD — powered by Venly.Dispatch.</description>
    <tags>dotnet-new template clean-architecture cqrs ddd venly dispatch dotnet10</tags>
